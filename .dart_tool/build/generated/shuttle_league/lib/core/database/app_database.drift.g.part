class Player extends DataClass implements Insertable<Player> {
  final String id;
  final String name;
  final int skillLevel;
  final int rating;
  final int wins;
  final int losses;
  final DateTime createdAt;
  const Player(
      {required this.id,
      required this.name,
      required this.skillLevel,
      required this.rating,
      required this.wins,
      required this.losses,
      required this.createdAt});
  @override
  Map<String, Expression> toColumns(bool nullToAbsent) {
    final map = <String, Expression>{};
    map['id'] = Variable<String>(id);
    map['name'] = Variable<String>(name);
    map['skill_level'] = Variable<int>(skillLevel);
    map['rating'] = Variable<int>(rating);
    map['wins'] = Variable<int>(wins);
    map['losses'] = Variable<int>(losses);
    map['created_at'] = Variable<DateTime>(createdAt);
    return map;
  }

  PlayersCompanion toCompanion(bool nullToAbsent) {
    return PlayersCompanion(
      id: Value(id),
      name: Value(name),
      skillLevel: Value(skillLevel),
      rating: Value(rating),
      wins: Value(wins),
      losses: Value(losses),
      createdAt: Value(createdAt),
    );
  }

  factory Player.fromJson(Map<String, dynamic> json,
      {ValueSerializer? serializer}) {
    serializer ??= driftRuntimeOptions.defaultSerializer;
    return Player(
      id: serializer.fromJson<String>(json['id']),
      name: serializer.fromJson<String>(json['name']),
      skillLevel: serializer.fromJson<int>(json['skillLevel']),
      rating: serializer.fromJson<int>(json['rating']),
      wins: serializer.fromJson<int>(json['wins']),
      losses: serializer.fromJson<int>(json['losses']),
      createdAt: serializer.fromJson<DateTime>(json['createdAt']),
    );
  }
  @override
  Map<String, dynamic> toJson({ValueSerializer? serializer}) {
    serializer ??= driftRuntimeOptions.defaultSerializer;
    return <String, dynamic>{
      'id': serializer.toJson<String>(id),
      'name': serializer.toJson<String>(name),
      'skillLevel': serializer.toJson<int>(skillLevel),
      'rating': serializer.toJson<int>(rating),
      'wins': serializer.toJson<int>(wins),
      'losses': serializer.toJson<int>(losses),
      'createdAt': serializer.toJson<DateTime>(createdAt),
    };
  }

  Player copyWith(
          {String? id,
          String? name,
          int? skillLevel,
          int? rating,
          int? wins,
          int? losses,
          DateTime? createdAt}) =>
      Player(
        id: id ?? this.id,
        name: name ?? this.name,
        skillLevel: skillLevel ?? this.skillLevel,
        rating: rating ?? this.rating,
        wins: wins ?? this.wins,
        losses: losses ?? this.losses,
        createdAt: createdAt ?? this.createdAt,
      );
  Player copyWithCompanion(PlayersCompanion data) {
    return Player(
      id: data.id.present ? data.id.value : this.id,
      name: data.name.present ? data.name.value : this.name,
      skillLevel:
          data.skillLevel.present ? data.skillLevel.value : this.skillLevel,
      rating: data.rating.present ? data.rating.value : this.rating,
      wins: data.wins.present ? data.wins.value : this.wins,
      losses: data.losses.present ? data.losses.value : this.losses,
      createdAt: data.createdAt.present ? data.createdAt.value : this.createdAt,
    );
  }

  @override
  String toString() {
    return (StringBuffer('Player(')
          ..write('id: $id, ')
          ..write('name: $name, ')
          ..write('skillLevel: $skillLevel, ')
          ..write('rating: $rating, ')
          ..write('wins: $wins, ')
          ..write('losses: $losses, ')
          ..write('createdAt: $createdAt')
          ..write(')'))
        .toString();
  }

  @override
  int get hashCode =>
      Object.hash(id, name, skillLevel, rating, wins, losses, createdAt);
  @override
  bool operator ==(Object other) =>
      identical(this, other) ||
      (other is Player &&
          other.id == this.id &&
          other.name == this.name &&
          other.skillLevel == this.skillLevel &&
          other.rating == this.rating &&
          other.wins == this.wins &&
          other.losses == this.losses &&
          other.createdAt == this.createdAt);
}

