    this.rating = const Value.absent(),
    this.wins = const Value.absent(),
    this.losses = const Value.absent(),
    required DateTime createdAt,
    this.rowid = const Value.absent(),
  })  : id = Value(id),
        name = Value(name),
        createdAt = Value(createdAt);
